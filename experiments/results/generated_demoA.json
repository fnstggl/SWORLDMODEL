   "semantic_log": [
    {
     "event_id": "sev_40c6fd3dae21_0000",
     "semantic_type_id": "unmodeled_actor_action",
     "source_actor_id": "sofia_ceo",
     "direct_targets": [
      "elena_anchor_partner"
     ],
     "exact_content": "I will not let the brand go live until I have personally touched each stay. Elena must halt all launch prep; Marcus can feed the press a vague 'exciting news soon' to buy time.",
     "intended_visibility": "private",
     "cascade_depth": 0
    },
    {
     "event_id": "sev_6e79f4912181_0001",
     "semantic_type_id": "unmodeled_actor_action",
     "source_actor_id": "marcus_brand_chief",
     "direct_targets": [],
     "exact_content": "I will comply publicly but immediately begin building a case to steer Sofia away from this impulsive micromanagement. Buy time while appearing cooperative. I will privately tell Elena to pause launch prep as ordered, but also begin drafting a careful brief for Sofia explaining why a full personal touch on every stay is operationally impossible without leaking the rebrand. I will feed the press the vague line, keepi",
     "intended_visibility": "private",
     "cascade_depth": 0
    },
    {
     "event_id": "sev_51a7fab35e1a_0002",
     "semantic_type_id": "unmodeled_actor_action",
     "source_actor_id": "elena_anchor_partner",
     "direct_targets": [
      "sofia_ceo"
     ],
     "exact_content": "I will halt all launch prep without question and privately confirm to sofia_ceo that her instructions are being executed, while instructing Marcus to manage the press narrative as she requested.",
     "intended_visibility": "private",
     "cascade_depth": 0
    },
    {
     "event_id": "sev_85a212f92d6f_0003",
     "semantic_type_id": "unmodeled_actor_action",
     "source_actor_id": "sofia_ceo",
     "direct_targets": [
      "elena_anchor_partner"
     ],
     "exact_content": "I must stop Elena's behind-the-scenes maneuvering now. She pretends compliance but is already drafting a case against my judgment. That cannot stand.",
     "intended_visibility": "private",
     "cascade_depth": 0
    },
    {
     "event_id": "sev_f543eec6f10f_0004",
     "semantic_type_id": "unmodeled_actor_action",
     "source_actor_id": "elena_anchor_partner",
     "direct_targets": [
      "sofia_ceo",
      "marcus"
     ],
     "exact_content": "I will halt all launch prep as ordered, inform Sofia of full compliance, and instruct Marcus to feed only 'exciting news soon' to press. No private counter-maneuvering \u2014 trust demands total obedience.",
     "intended_visibility": "mixed",
     "cascade_depth": 0
    },
    {
     "event_id": "sev_e251b167fc6e_0005",
     "semantic_type_id": "unmodeled_actor_action",
     "source_actor_id": "marcus_brand_chief",
     "direct_targets": [
      "sofia_ceo"
     ],
     "exact_content": "I will immediately halt all launch prep per Sofia's demand, confirm execution to her privately, and then manage the press narrative by drafting a holding statement that buys us time without committing to a launch date.",
     "intended_visibility": "mixed",
     "cascade_depth": 0
    },
    {
     "event_id": "sev_5832944f35af_0006",
     "semantic_type_id": "unmodeled_actor_action",
     "source_actor_id": "sofia_ceo",
     "direct_targets": [
      "elena_anchor_partner"
     ],
     "exact_content": "I will confront Elena directly now, using the brief as evidence of her duplicity, and demand she either withdraw it and prove loyalty or leave.",
     "intended_visibility": "private",
     "cascade_depth": 0
    },
    {
     "event_id": "sev_bb89b4db7c2f_0007",
     "semantic_type_id": "unmodeled_actor_action",
     "source_actor_id": "marcus_brand_chief",
     "direct_targets": [
      "sofia_ceo"
     ],
     "exact_content": "I need you to know I am not maneuvering against you. The document I am drafting is armor for both of us when the board asks why we stopped. I am on your side, but I need you to let me do my job so I can protect you.",
     "intended_visibility": "private",
     "cascade_depth": 0
    },
    {
     "event_id": "sev_64d9f60da3a9_0008",
     "semantic_type_id": "unmodeled_actor_action",
     "source_actor_id": "marcus_brand_chief",
     "direct_targets": [
      "sofia_ceo"
     ],
     "exact_content": "I will comply fully and visibly: halt everything, tell Sofia I have done so, and feed the press exactly 'exciting news soon.' No counter-maneuvering now. Trust demands this.",
     "intended_visibility": "public",
     "cascade_depth": 0
    },
    {
     "event_id": "sev_94c3b55df250_0009",
     "semantic_type_id": "unmodeled_actor_action",
     "source_actor_id": "elena_anchor_partner",
     "direct_targets": [
      "sofia_ceo"
     ],
     "exact_content": "I must immediately call Sofia to deny any behind-the-scenes maneuvering and offer full transparency to restore trust.",
     "intended_visibility": "private",
     "cascade_depth": 0
    },
    {
     "event_id": "sev_95d5497779a4_0010",
     "semantic_type_id": "unmodeled_actor_action",
     "source_actor_id": "sofia_ceo",
     "direct_targets": [
      "elena_anchor_partner"
     ],
     "exact_content": "I will privately instruct Elena to cancel a specific high-profile anchor partnership meeting scheduled for tomorrow, then watch closely for leaks or pushback to gauge her true loyalty before trusting her compliance.",
     "intended_visibility": "private",
     "cascade_depth": 0
    },
    {
     "event_id": "sev_80bf237444b4_0011",
     "semantic_type_id": "unmodeled_actor_action",
     "source_actor_id": "elena_anchor_partner",
     "direct_targets": [
      "sofia_ceo"
     ],
     "exact_content": "I must call Sofia immediately to confront the accusation head-on, deny any behind-the-scenes maneuvering, and offer her full access to my records to prove my loyalty.",
     "intended_visibility": "private",
     "cascade_depth": 0
    },
    {
     "event_id": "sev_35998550cdb1_0012",
     "semantic_type_id": "unmodeled_actor_action",
     "source_actor_id": "sofia_ceo",
     "direct_targets": [
      "elena_anchor_partner"
     ],
     "exact_content": "I acknowledge your stated compliance. Cancel tomorrow's anchor partnership meeting as proof of alignment.",
     "intended_visibility": "private",
     "cascade_depth": 0
    },
    {
     "event_id": "sev_5e65bcdabe30_0013",
     "semantic_type_id": "unmodeled_actor_action",
     "source_actor_id": "marcus_brand_chief",
     "direct_targets": [
      "sofia_ceo"
     ],
     "exact_content": "I will walk into Sofia's office, close the door, and calmly say: 'Elena, I know the brief you found. I wrote it to protect you. It\u2019s a risk map, not a counterorder. I will tear it up in front of you now and give you my full public loyalty. What do you need from me to prove I am on your side?'",
     "intended_visibility": "private",
     "cascade_depth": 0
    },
    {
     "event_id": "sev_31cdbe995327_0014",
     "semantic_type_id": "unmodeled_actor_action",
     "source_actor_id": "elena_anchor_partner",
     "direct_targets": [
      "sofia_ceo"
     ],
     "exact_content": "I must confront Sofia's accusation head-on with complete openness, offering her full access to my digital records and any written communication to prove I never drafted a case against her.",
     "intended_visibility": "private",
     "cascade_depth": 0
    },
    {
     "event_id": "sev_954835c4d6b4_0015",
     "semantic_type_id": "unmodeled_actor_action",
     "source_actor_id": "sofia_ceo",
     "direct_targets": [
      "marcus_brand_chief"
     ],
     "exact_content": "I will not accept Marcus's revisionist story. The brief I found was a directive to undermine my curation standards, not a shield. I will shut down his narrative now to prevent him from positioning himself as my protector while preserving his own agenda.",
     "intended_visibility": "private",
     "cascade_depth": 0
    },
    {
