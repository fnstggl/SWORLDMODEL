experiments/results/exp075/cmv_perop.json

experiments/results/exp085/senate_bills.json
experiments/results/*.log

# the outcome-flywheel stream IS the moat — track it (data/ is otherwise ignored)
!data/forecast_log.jsonl
!data/dataset_registry.json
!data/forward_ledger.jsonl
experiments/results/higgs_nl_cache/

# per-compile reproducibility cache (compile_world persists every attempt at runtime, incl. during tests);
# the mechanism IS the reproducibility guarantee, but the transient artifacts are re-derivable and not committed.
# Committed evidence of generality lives in experiments/results/compiler_generality/ + the validation JSONs.
experiments/results/compiler_attempts/

# machine-readable mechanism registry IS a deliverable (data/ is otherwise ignored)
!swm/world_model_v2/registry/data/
!swm/world_model_v2/registry/data/*.json
