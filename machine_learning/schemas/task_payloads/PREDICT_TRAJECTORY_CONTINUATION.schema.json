{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sworldmodel/schemas/task_payloads/PREDICT_TRAJECTORY_CONTINUATION.schema.json",
  "title": "PredictTrajectoryContinuation",
  "description": "Predict the next K events of an episode given its prefix.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "input",
    "target"
  ],
  "properties": {
    "input": {
      "type": "object",
      "additionalProperties": true,
      "required": [],
      "properties": {
        "history": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "horizon": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of future events to predict (K)."
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "continuation"
      ],
      "properties": {
        "continuation": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    }
  }
}
