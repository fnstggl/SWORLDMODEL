      "b": {"action_name": "escalate", "target": "bob"},
      "known_entities": ["bob"],
      "expected": "same",
      "why": "The compiled novel action carries a validated ontology anchor 'escalate'; anchoring means the same causal act as the plain ontology action."
    },
